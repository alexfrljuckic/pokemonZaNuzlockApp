{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nuzlocke.example/schemas/game.schema.json",
  "title": "Nuzlocke Game Dataset",
  "type": "object",
  "required": ["schemaVersion", "gameId", "name", "versions", "areas", "specials", "milestones", "mechanics"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "gameId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "versions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } },
    "pokeapiVersionGroups": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "description": "PokeAPI version-group slugs whose move-learn data applies to this game (include DLC groups). Omit/empty when PokeAPI has no move data for the game (e.g. Legends Z-A) — the app then falls back to the all-games union movepool."
    },
    "rostersRequired": {
      "type": "boolean",
      "description": "When true, the validator fails if any milestone lacks a roster (or rosterByStarter). Set once a game's rosters are complete so a future edit or dataset can't silently ship 0/N rosters (as Legends Z-A partially does — it omits this flag)."
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "unlockAfter", "tags", "encounters"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "unlockAfter": { "type": ["string", "null"] },
          "tags": { "type": "array", "items": { "type": "string" } },
          "encounters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["species", "methods"],
              "additionalProperties": false,
              "properties": {
                "species": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "methods": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                "rate": { "type": "number", "minimum": 0 },
                "conditions": {
                  "type": "object",
                  "additionalProperties": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          },
          "trainers": {
            "type": "array",
            "description": "Optional documented trainer battles in this area (Serebii/Bulbapedia-sourced, never invented). Display-only route intel — the engine doesn't gate anything on them.",
            "items": {
              "type": "object",
              "required": ["name", "team"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "class": { "type": "string", "description": "Trainer class, e.g. \"Youngster\", \"Ace Trainer\"." },
                "team": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["species", "level"],
                    "additionalProperties": false,
                    "properties": {
                      "species": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                      "level": { "type": "integer", "minimum": 1 },
                      "moves": { "type": "array", "items": { "type": "string" } },
                      "ability": { "type": "string" },
                      "heldItem": { "type": "string" }
                    }
                  }
                },
                "conditions": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": { "version": { "type": "array", "items": { "type": "string" } } }
                }
              }
            }
          },
          "items": {
            "type": "array",
            "description": "Optional fixed overworld item pickups in this area (Serebii/Bulbapedia-sourced; shop stock, renewables and quest rewards excluded). Display-only route intel.",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "hidden": { "type": "boolean", "description": "Hidden pickup (Dowsing Machine / Itemfinder spot)." },
                "quantity": { "type": "integer", "minimum": 2, "description": "Only when a single pickup yields more than one." },
                "conditions": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": { "version": { "type": "array", "items": { "type": "string" } } }
                }
              }
            }
          }
        }
      }
    },
    "specials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "species", "area"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "type": { "enum": ["gift", "static", "trade", "fossil", "egg"] },
          "species": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "area": { "type": "string" },
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "version": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "order", "aceLevel"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string" },
          "order": { "type": "integer", "minimum": 0 },
          "aceLevel": { "type": ["integer", "null"], "minimum": 1 },
          "countsForLevelCap": {
            "type": "boolean",
            "description": "Whether this milestone gates the enforced level cap. Defaults to true when absent; set false for milestones (e.g. rival battles) that should be tracked/displayed but not cap-gating."
          },
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "version": { "type": "array", "items": { "type": "string" } } },
            "description": "Optional version gating for a milestone present in only one version (e.g. the Scarlet/Violet Area Zero finale, or the version-split Quaking Earth Titan). The app shows it only for matching run versions."
          },
          "trainerSprite": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Showdown trainer-sprite key for this battle, when the default guess (the milestone id's last segment) is wrong — e.g. rival-hop-1 needs \"hop\". Datasets own presentation data per the game-content-is-JSON principle; the app falls back to the guess, and the sprite hides itself on a miss."
          },
          "grants": {
            "type": "object",
            "additionalProperties": false,
            "properties": { "reviveTokens": { "type": "integer", "minimum": 0 } }
          },
          "roster": {
            "type": "array",
            "description": "Optional full team, informational only — the level-cap rule reads aceLevel, never this. Default shown when no starter is chosen.",
            "items": {
              "type": "object",
              "required": ["species", "level"],
              "additionalProperties": false,
              "properties": {
                "species": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "level": { "type": "integer", "minimum": 1 },
                "moves": { "type": "array", "items": { "type": "string" } },
                "ability": { "type": "string" },
                "heldItem": { "type": "string" },
                "teraType": { "type": "string", "description": "Terastal type the ace Terastallizes into (Scarlet/Violet). Data-only." }
              }
            }
          },
          "rosterByStarter": {
            "type": "object",
            "description": "Optional per-player-starter roster variants (rival battles), keyed by the player's chosen starter species slug (e.g. turtwig/chimchar/piplup). The app uses the matching variant when a starter is chosen, else falls back to `roster`.",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["species", "level"],
                "additionalProperties": false,
                "properties": {
                  "species": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                  "level": { "type": "integer", "minimum": 1 },
                  "moves": { "type": "array", "items": { "type": "string" } },
                  "ability": { "type": "string" },
                  "heldItem": { "type": "string" },
                  "teraType": { "type": "string", "description": "Terastal type the ace Terastallizes into (Scarlet/Violet). Data-only." }
                }
              }
            }
          }
        }
      }
    },
    "mechanics": {
      "type": "object",
      "required": ["heldItems", "wildBattles", "setModeOption", "raids", "overworldAggro"],
      "additionalProperties": false,
      "properties": {
        "heldItems": { "type": "boolean" },
        "wildBattles": { "type": "boolean" },
        "setModeOption": { "type": "boolean" },
        "raids": { "type": "boolean" },
        "overworldAggro": { "type": "boolean" }
      }
    }
  }
}
